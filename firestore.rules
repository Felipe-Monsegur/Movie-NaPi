rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserAllowed() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/allowedUsers/$(request.auth.uid)) ||
         exists(/databases/$(database)/documents/allowedUsers/$(request.auth.token.email)));
    }

    match /allowedUsers/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /userSettings/{userId} {
      allow read, write: if isUserAllowed() && request.auth.uid == userId;
    }

    match /movies/{movieId} {
      allow read, create, update, delete: if isUserAllowed();
    }

    match /movieRatings/{ratingId} {
      allow read: if isUserAllowed();
      allow create, update: if isUserAllowed() && request.resource.data.userId == request.auth.uid;
      allow delete: if isUserAllowed();
    }
  }
}
